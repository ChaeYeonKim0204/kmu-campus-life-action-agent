# OpenAI API access
# 팀별 키 (교수 지급, 팀장이 메일로 공유받아 팀원에 배포).
# 절대 commit 금지 — 이 .env.example만 트래킹되고 실제 .env는 .gitignore로 보호됨.
OPENAI_API_KEY=

# LLM 보조 게이트 (둘 다 true여야 polish까지 켜짐)
OPENAI_ENABLED=true
OPENAI_POLISH_ENABLED=true

# 모델 — 교수 지침: gpt-5-mini 우선 (비용 의식)
OPENAI_MODEL=gpt-5-mini
OPENAI_GRADUATION_MODEL=gpt-5-mini

# 졸업센터 Vision OCR — gpt-5-mini의 vision 지원이 불확실해 gpt-4o로 분리 유지
OPENAI_GRADUATION_VISION_MODEL=gpt-4o
